# Database (PostgreSQL - local dev or Railway)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/propforge

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-here-min-32-chars
BETTER_AUTH_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# Resend (Email)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@propforge.dev

# Twilio (SMS)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Plaid (Banking)
PLAID_CLIENT_ID=...
PLAID_SECRET=...
PLAID_ENV=sandbox

# S3-Compatible Storage
S3_BUCKET=propforge-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=...
S3_SECRET_ACCESS_KEY=...
S3_ENDPOINT=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
